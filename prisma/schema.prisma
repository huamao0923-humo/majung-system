generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// в”Җв”Җв”Җ и¶…зҙҡз®ЎзҗҶе“ЎпјҲдёҚеұ¬ж–јд»»дҪ•з§ҹжҲ¶пјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model SuperAdmin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// в”Җв”Җв”Җ з§ҹжҲ¶пјҲжҜҸй–“йә»е°ҮйӨЁпјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Tenant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  lineChannelId      String?
  lineChannelSecret  String?
  lineMessagingToken String?
  lineLiffId         String?
  isActive              Boolean  @default(true)
  plan                  String   @default("basic")
  // иЁӮдҪҚиҰҸеүҮиЁӯе®ҡ
  cancelDeadlineHours   Int      @default(2)   // еҸ–ж¶ҲжҲӘжӯўпјҲе ҙж¬ЎеүҚе№ҫе°ҸжҷӮпјү
  minAdvanceHours       Int      @default(1)   // жңҖе°‘жҸҗеүҚе№ҫе°ҸжҷӮиЁӮдҪҚ
  maxAdvanceDays        Int      @default(14)  // жңҖеӨҡжҸҗеүҚе№ҫеӨ©иЁӮдҪҚ
  createdAt             DateTime @default(now())

  users           User[]
  floors          Floor[]
  tables          Table[]
  timeSlots       TimeSlot[]
  announcements   Announcement[]
  reservations    Reservation[]
  waitlistEntries WaitlistEntry[]
  closedDates     ClosedDate[]
}

// в”Җв”Җв”Җ дј‘жҒҜж—Ҙз®ЎзҗҶв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model ClosedDate {
  id        String   @id @default(cuid())
  tenantId  String
  date      String   // YYYY-MM-DD
  reason    String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
}

// в”Җв”Җв”Җ жЁ“еұӨпјҲжҜҸеҖӢз§ҹжҲ¶еҸҜжңүеӨҡеұӨпјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Floor {
  id       String @id @default(cuid())
  tenantId String
  name     String
  order    Int    @default(0)

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tables Table[]
}

// в”Җв”Җв”Җ з”ЁжҲ¶пјҲLINE зҷ»е…ҘпјҢд»Ҙ tenantId+lineUserId е”ҜдёҖиӯҳеҲҘпјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model User {
  id            String   @id @default(cuid())
  tenantId      String
  lineUserId    String
  displayName   String
  pictureUrl    String?
  phone         String?
  role          String   @default("member")
  username      String?  @unique
  passwordHash  String?
  isBlacklisted Boolean  @default(false)
  noShowCount   Int      @default(0)
  createdAt     DateTime @default(now())

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations    Reservation[]
  waitlistEntries WaitlistEntry[]

  @@unique([tenantId, lineUserId])
}

// в”Җв”Җв”Җ жЎҢдҪҚпјҲеҗ«е№ійқўең–дҪҚзҪ®пјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Table {
  id          String  @id @default(cuid())
  tenantId    String
  floorId     String
  name        String
  capacity    Int     @default(4)
  posX        Float   @default(10)
  posY        Float   @default(10)
  tableWidth  Float   @default(22)
  tableHeight Float   @default(14)
  isActive    Boolean @default(true)
  order       Int     @default(0)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  floor        Floor         @relation(fields: [floorId], references: [id], onDelete: Cascade)
  reservations Reservation[]
}

// в”Җв”Җв”Җ жҷӮж®өв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model TimeSlot {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  startTime String
  endTime   String
  price     Int     @default(0)
  isActive  Boolean @default(true)
  order     Int     @default(0)

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations    Reservation[]
  waitlistEntries WaitlistEntry[]
}

// в”Җв”Җв”Җ й җзҙ„в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Reservation {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  tableId     String
  timeSlotId  String
  date        DateTime
  guestCount  Int
  status      String    @default("pending")
  note        String?
  checkedInAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  table    Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  timeSlot TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)
  payment  Payment?
}

// в”Җв”Җв”Җ д»ҳж¬ҫв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Payment {
  id            String    @id @default(cuid())
  reservationId String    @unique
  amount        Int
  method        String?
  status        String    @default("unpaid")
  paidAt        DateTime?
  confirmedBy   String?
  note          String?
  createdAt     DateTime  @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

// в”Җв”Җв”Җ еҖҷиЈңеҗҚе–®в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model WaitlistEntry {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  timeSlotId String
  date       DateTime
  guestCount Int
  notified   Boolean  @default(false)
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeSlot TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)
}

// в”Җв”Җв”Җ е…¬е‘Ҡв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Announcement {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
